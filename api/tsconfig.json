{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "esnext",
    "lib": ["esnext"],
    "types": ["node"],
    "sourceMap": true,
    "declaration": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/controllers/attendance",
    "src/controllers/drivers",
    "src/controllers/workers",
    "src/routes/attendance.routes.ts",
    "src/routes/driver.routes.ts",
    "src/routes/worker.routes.ts",
    "src/middlewares/roleGuard.ts"
  ]
}
