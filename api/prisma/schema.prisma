// ─── Attendance ───────────────────────────────────────────────────────────────

model Shift {
  id         String      @id @default(uuid()) @db.Uuid
  employeeId String      @map("employee_id") @db.Uuid
  shiftDate  DateTime    @map("shift_date") @db.Date
  checkIn    DateTime?   @map("check_in")
  checkOut   DateTime?   @map("check_out")
  status     ShiftStatus @default(ABSENT)
  createdAt  DateTime    @default(now()) @map("created_at")

  employee OutletEmployee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, shiftDate])
  @@map("shifts")
}

// ─── Pricing ──────────────────────────────────────────────────────────────────

model LaundryItem {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(100)
  unit      String   @default("pcs") @db.VarChar(20)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  outletItemPrices OutletItemPrice[]
  orderItems       OrderItem[]
  stationItems     StationItem[]

  @@map("laundry_items")
}

model OutletItemPrice {
  id            String   @id @default(uuid()) @db.Uuid
  outletId      String   @map("outlet_id") @db.Uuid
  laundryItemId String   @map("laundry_item_id") @db.Uuid
  pricePerUnit  Decimal  @map("price_per_unit") @db.Decimal(10, 2)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  outlet      Outlet      @relation(fields: [outletId], references: [id])
  laundryItem LaundryItem @relation(fields: [laundryItemId], references: [id])

  @@unique([outletId, laundryItemId])
  @@map("outlet_item_prices")
}

